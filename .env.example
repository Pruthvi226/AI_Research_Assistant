# Scientia.ai - Environment Variables Configuration Template
# Duplicate this file as '.env' and fill in your keys.

# Flask settings
APP_NAME=Scientia.ai
APP_VERSION=1.0.0
ENVIRONMENT=local
SECRET_KEY=your_super_secret_key_change_in_production
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000
REQUEST_ID_HEADER=X-Request-ID
MAX_UPLOAD_MB=50
ADMIN_API_KEY=change_me_for_public_deployments
REQUIRE_ADMIN_AUTH=false
SECURITY_HEADERS_ENABLED=true

# AI / LLM keys
GEMINI_API_KEY=your_gemini_api_key_here
GITHUB_TOKEN=your_optional_github_token_here

# Provider models
AI_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o-mini

# Local performance defaults
USE_SEMANTIC_EMBEDDINGS=false
USE_TRANSFORMER_FALLBACK=false
DATA_FOLDER=/app/data
UPLOAD_FOLDER=/app/data/uploads
INDEX_FOLDER=/app/data/faiss_index
AUDIO_FOLDER=/app/data/generated_audio
GENERATED_CODE_FOLDER=/app/data/generated_code
GENERATED_MARKDOWN_FOLDER=/app/data/generated_markdown
DATABASE_URL=sqlite:////app/data/scientia.db
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_WINDOW_SECONDS=60
JOB_WORKERS=3
JOB_MAX_IN_FLIGHT=50
JOB_RETENTION_LIMIT=500

# Frontend local development
REACT_APP_API_URL=
REACT_APP_ADMIN_API_KEY=
