# Scientia.ai - Environment Variables Configuration Template
# Duplicate this file as '.env' and fill in your keys.

# Flask settings
SECRET_KEY=your_super_secret_key_change_in_production

# AI / LLM Keys (Gemini is recommended and highly integrated)
GEMINI_API_KEY=AIzaSy...your_gemini_key_here
# Optional: OpenAI integrations (fallback option)
OPENAI_API_KEY=sk-...your_openai_key_here

# Provider models
AI_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o-mini

# Database (for FastAPI stubs, default SQLite is used in Flask)
SQLALCHEMY_DATABASE_URI=postgresql://postgres:postgress_password@db:5432/ai_researcher
REDIS_HOST=redis
